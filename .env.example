# OpenAI API Key (Required for GPT-4o models)
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API Key (Required for web search tools)
TAVILY_API_KEY=your_tavily_api_key_here

# HuggingFace Token (Required for downloading models or using HF Hub)
HF_TOKEN=your_huggingface_token_here

# Optional: LangChain Tracing (Useful for debugging graphs)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=startup-invest-agent
